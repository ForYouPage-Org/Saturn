# Client-side vars. Only needed for native (iOS/Android) builds.
# On web the bundle is served from the same origin as the API, so /api/* is
# just a relative URL and no env var is required.
#
# For native builds, set this to the public URL (e.g. the ngrok URL that fronts
# the iMac). Without a scheme prefix it falls back to relative paths.
EXPO_PUBLIC_API_URL=
