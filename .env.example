# Client-side — safe to ship (Supabase anon key uses RLS)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side — set in Supabase edge function secrets, NEVER in client
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_BASE_URL=https://nexhelm-ai-marx.openai.azure.com/openai/v1
# AZURE_OPENAI_MODEL=gpt-5.4
# AZURE_OPENAI_API_VERSION=preview
