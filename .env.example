# Client-side build-time vars. Baked into the Next.js bundle at build.
# scripts/push_and_deploy.sh rsyncs this file to the target before `next build`.
#
# Next.js's basePath gives us server-side URL routing, but client `fetch()`
# calls aren't auto-prefixed — so lib/api-client.ts reads this var to build
# absolute /pilot/api/* paths on the browser side.
#
# For local dev (no tailscale), leave empty:
#   NEXT_PUBLIC_BASE_PATH=
# For prod (matches the tailscale funnel set-path + next.config basePath):
NEXT_PUBLIC_BASE_PATH=/pilot
