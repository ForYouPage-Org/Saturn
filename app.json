{
  "expo": {
    "name": "Mercury",
    "slug": "mercury",
    "scheme": "mercury",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "edu.research.mercury"
    },
    "android": {
      "package": "edu.research.mercury",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "experiments": {
      "baseUrl": "/pilot"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#000000"
        }
      ]
    ],
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": ""
    }
  }
}
