# Copy to ~/.mercury-pilot-push.env and fill in. Chmod 600.
# Used by scripts/push_and_deploy.sh on the SOURCE Mac.
#
# The repo lives at https://github.com/ForYouPage-Org/Saturn (the Saturn name
# survived from the earlier ActivityPub project; archive/social-app branch
# holds the pre-pilot code). Clone on the iMac with:
#   git clone https://github.com/ForYouPage-Org/Saturn.git <target-path>

# Tailscale hostname of the target (prod) Mac.
# MagicDNS bare name is fine within the tailnet.
MERCURY_PILOT_TARGET_HOST=marxs-imac

# Absolute path on the target Mac where the repo is cloned.
# Can be anything — the clone doesn't have to be named "mercury" or "Saturn".
MERCURY_PILOT_TARGET_PATH=/Users/marxw/Research/projects/mercury

# SSH user on the target. Defaults to $USER if unset.
MERCURY_PILOT_TARGET_USER=marxw

# Branch to deploy from origin. Defaults to main.
# MERCURY_PILOT_BRANCH=main
