# Copy to secrets/server.env (chmod 600) on any mac that runs the server.
# secrets/ is gitignored — these values never get committed.
# scripts/push_and_deploy.sh rsyncs this file from source → target.

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=https://nexhelm-ai-marx.openai.azure.com/openai/v1
AZURE_OPENAI_MODEL=gpt-5.4
AZURE_OPENAI_API_VERSION=preview
AZURE_OPENAI_REASONING_EFFORT=high

# Appends one JSONL line per /api/chat to this file. Point it at the hub's
# log and the hub's /admin/azure-usage dashboard picks up mercury-pilot
# traffic automatically — no hub code changes needed.
#   On marxs-imac (prod):   /Users/marx/Developer/_mercury/logs/azure_usage.jsonl
#   On the MacBook (dev):   /Users/marxw/Research/_hub/logs/azure_usage.jsonl
AZURE_USAGE_LOG_PATH=/Users/marx/Developer/_mercury/logs/azure_usage.jsonl
# Optional: override the per-1M pricing used to estimate cost_usd.
# Defaults match the hub (1.25 in / 10.0 out for gpt-5.x).
# AZURE_OPENAI_INPUT_PRICE_PER_M=1.25
# AZURE_OPENAI_OUTPUT_PRICE_PER_M=10.0

# Required to call POST /api/admin/esm-trigger. Generate once with:
#   openssl rand -base64 32
MERCURY_ADMIN_TOKEN=

# Hub SSO — same hex value as _hub/secrets/session_secret. When set, anyone
# already signed in as a hub admin (hub `mercury_session` cookie on the same
# hostname) is treated as authenticated on /pilot/admin too — no second
# sign-in. Optional; if unset, pilot falls back to the
# MERCURY_ADMIN_TOKEN-only login flow.
HUB_SESSION_SECRET_HEX=
